# App
APP_NAME="Tika Law"
APP_ENV=development
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database: Supabase/PostgreSQL compatible
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tika_law

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Attorney notifications
ATTORNEY_NOTIFICATION_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
